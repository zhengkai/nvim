{
	"languageserver": {
		"efm": {
			"command": "efm-langserver",
			"args": [],
			"filetypes": ["vim", "eruby", "markdown", "yaml"]
		},
		"go": {
			"command": "gopls",
			"rootPatterns": ["go.mod"],
			"trace.server": "verbose",
			"filetypes": ["go"]
		},
		"dockerfile": {
			"command": "docker-langserver",
			"filetypes": ["dockerfile"],
			"args": ["--stdio"]
		}
	}
}
